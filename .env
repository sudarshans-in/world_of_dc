# =============================================================================
# MONGODB ATLAS CONFIGURATION (PRODUCTION)
# =============================================================================
# Replace with your actual MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://admin:admin@cluster0.ay8sec7.mongodb.net/?appName=Cluster0

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your_secure_jwt_secret_here_minimum_256_bits_long_and_random

# JWT Token Expiration (in milliseconds)
JWT_EXPIRATION_MS=3600000

# =============================================================================
# SMS/OTP CONFIGURATION
# =============================================================================
# SMS Provider and API Key
SMS_PROVIDER=console
SMS_API_KEY=your_actual_sms_api_key
SMS_SENDER_ID=CACHAR

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
FILE_UPLOAD_DIR=/app/uploads
FILE_MAX_SIZE=10485760

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
COMPLAINT_NUMBER_PREFIX=CCR
COMPLAINT_NUMBER_LENGTH=18

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_APP=INFO
